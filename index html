<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FANatical</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <div class="sidebar">

        <ul class="nav-top">
            <li onclick="showPage('home')"><img src="images/icons/home.png" alt="Home">Home</li>
            <li onclick="showPage('news')"><img src="images/icons/news.png" alt="News">News</li>
            <li onclick="showPage('events')"><img src="images/icons/events.png" alt="Events">Events</li>
            <li onclick="showPage('cheer')"><img src="images/icons/cheer.png" alt="Cheer">Cheer</li>
            <li onclick="showPage('quiz')"><img src="images/icons/quiz.jpeg" alt="Quiz">Quiz</li>
        </ul>

        <ul class="nav-bottom">
            <li onclick="showPage('profile')"><img src="images/icons/profile.png" alt="Profile">Profile</li>
            <li><img src="images/icons/settings.png" alt="Settings">Settings</li>
        </ul>
    </div>

    <div class="main">
        <div class="topbar">
    <div class="topbar-left">
        <img src="images/icons/fanatical.png" alt="FANatical">
    </div>

    <div class="profile-icon" onclick="showPage('profile')">
        <img src="images/icons/profile.png" alt="Profile">
    </div>
</div>

     <div id="home" class="page">

    <div class="team-bar">
        <span>Oilers</span>
        <span>Elks</span>
        <span>Jays</span>
        <span>Add Team</span>
    </div>

    <div class="hero-box">
  <img src="/images/logos/main-image.jpg" alt="Main">
</div>
    </div>

</div>

        <div id="news" class="page" style="display:none;">
            <h1>News</h1>
            <div class="subnav">My Feed | Discover | Saved</div>
            <div class="content-box">News content area</div>
        </div>

        <div id="events" class="page" style="display:none;">
            <h1>Events</h1>
            <div class="subnav">Calendar | Tailgates | Watch Parties | Check-In</div>
            <div class="content-box">Events content area</div>
        </div>

        <div id="cheer" class="page" style="display:none;">
            <h1>Cheer</h1>
            <div class="subnav">Browse | Create | Live | My Cheers</div>
            <div class="content-box">Cheer content area</div>
        </div>

        <div id="quiz" class="page" style="display:none;">
            <h1>Quiz</h1>
            <div class="subnav">Browse | Create | Live | My Quizzes</div>
            <div class="content-box">Quiz content area</div>
        </div>

        <div id="profile" class="page" style="display:none;">
            <h1>Profile</h1>
            <div class="subnav">Card | FANcave | Game Face | Memorabilia</div>
            <div class="content-box">Profile content area</div>
        </div>
    </div>

    <script>
        function showPage(pageId) {
            const pages = document.querySelectorAll('.page');
            pages.forEach(page => page.style.display = 'none');
            document.getElementById(pageId).style.display = 'block';
        }
    </script>

</body>
</html>
